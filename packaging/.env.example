# packaging/.env.example — copy to packaging/.env and fill in values.
#
# Compose substitutes `${VAR}` references in docker-compose.yml with values
# read from this file at `docker compose up` time. NEVER commit your real
# values — config.json, .env, and credentials*.json are all gitignored.

# ---- Telegram credentials --------------------------------------------------
# https://my.telegram.org/apps for api_id / api_hash.
# https://t.me/BotFather for the bot token.
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=00000000000000000000000000000000
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
OWNER_ID=000000000

# ---- aria2 RPC -------------------------------------------------------------
# Used by both the aria2 service and the bot. Pick a strong random secret.
ARIA2_SECRET=change-me-to-a-long-random-string

# ---- Operational ----------------------------------------------------------
LOG_LEVEL=info
TZ=UTC

# UID/GID the aria2 container runs as. Defaults to 1000 (typical first user
# on Linux). Match the owner of the bind-mounted downloads/ to avoid
# permission surprises.
PUID=1000
PGID=1000

# Image tag override. Pin in production; "latest" is fine for development.
CMLB_TAG=latest

# Build metadata (CI populates these; local dev leaves them as defaults).
GIT_SHA=dev
BUILD_DATE=unknown
