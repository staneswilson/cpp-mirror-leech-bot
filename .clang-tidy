# CMLB clang-tidy configuration.
# Requires clang-tidy >= 17. WarningsAsErrors enforces a clean tree in CI.
#
# Check groups enabled:
#   bugprone-*, modernize-*, performance-*, cert-*, cppcoreguidelines-*,
#   readability-*, misc-*, concurrency-*
#
# Targeted disables (each with a one-line rationale):
#   -modernize-use-trailing-return-type  -- stylistic; we prefer leading return types.
#   -readability-magic-numbers           -- noisy in tests/benchmarks; values are intentional.
#   -cppcoreguidelines-avoid-magic-numbers -- duplicate of the readability check above.
#   -bugprone-easily-swappable-parameters -- false positives on adapter ctors and DTOs.
#   -readability-identifier-length       -- we use short names like `id`, `os`, `it`.
#   -modernize-use-nodiscard             -- noisy on void-equivalent getters; opt-in case by case.
#   -cppcoreguidelines-pro-bounds-pointer-arithmetic -- unavoidable at FFI boundaries (TDLib).
#   -cppcoreguidelines-pro-type-reinterpret-cast     -- needed for span<std::byte> conversions.
#   -cppcoreguidelines-avoid-do-while                -- legitimate idiom for retry loops.
#   -misc-non-private-member-variables-in-classes    -- duplicates cppcoreguidelines- variant.
#   -misc-include-cleaner                -- handled by IWYU separately; too aggressive here.
#   -modernize-use-designated-initializers -- C++20 designated init still has rough edges.

---
Checks: >
    bugprone-*,
    modernize-*,
    performance-*,
    cert-*,
    cppcoreguidelines-*,
    readability-*,
    misc-*,
    concurrency-*,
    -modernize-use-trailing-return-type,
    -readability-magic-numbers,
    -cppcoreguidelines-avoid-magic-numbers,
    -bugprone-easily-swappable-parameters,
    -readability-identifier-length,
    -modernize-use-nodiscard,
    -cppcoreguidelines-pro-bounds-pointer-arithmetic,
    -cppcoreguidelines-pro-type-reinterpret-cast,
    -cppcoreguidelines-avoid-do-while,
    -misc-non-private-member-variables-in-classes,
    -misc-include-cleaner,
    -modernize-use-designated-initializers

WarningsAsErrors: '*'

# Only lint our own headers; vcpkg/system headers are out of scope.
HeaderFilterRegex: '^.*include/cmlb/.*\.hpp$'

# Apply formatting fixes that clang-tidy suggests using our .clang-format rules.
FormatStyle: file

# Naming conventions match the project style guide.
CheckOptions:
    # Classes, structs, enums -- PascalCase.
    - key: readability-identifier-naming.ClassCase
      value: CamelCase
    - key: readability-identifier-naming.StructCase
      value: CamelCase
    - key: readability-identifier-naming.EnumCase
      value: CamelCase
    - key: readability-identifier-naming.UnionCase
      value: CamelCase
    - key: readability-identifier-naming.TypeAliasCase
      value: CamelCase
    - key: readability-identifier-naming.TypedefCase
      value: CamelCase
    - key: readability-identifier-naming.TemplateParameterCase
      value: CamelCase

    # Functions / methods -- snake_case.
    - key: readability-identifier-naming.FunctionCase
      value: lower_case
    - key: readability-identifier-naming.MethodCase
      value: lower_case

    # Variables and parameters -- snake_case.
    - key: readability-identifier-naming.VariableCase
      value: lower_case
    - key: readability-identifier-naming.ParameterCase
      value: lower_case
    - key: readability-identifier-naming.LocalVariableCase
      value: lower_case

    # Member fields -- snake_case with trailing underscore (per style guide).
    - key: readability-identifier-naming.PrivateMemberCase
      value: lower_case
    - key: readability-identifier-naming.PrivateMemberSuffix
      value: '_'
    - key: readability-identifier-naming.ProtectedMemberCase
      value: lower_case
    - key: readability-identifier-naming.ProtectedMemberSuffix
      value: '_'
    - key: readability-identifier-naming.PublicMemberCase
      value: lower_case

    # Constants and enum values -- snake_case (we lean on enum class).
    - key: readability-identifier-naming.EnumConstantCase
      value: lower_case
    - key: readability-identifier-naming.GlobalConstantCase
      value: lower_case
    - key: readability-identifier-naming.StaticConstantCase
      value: lower_case
    - key: readability-identifier-naming.ConstexprVariableCase
      value: lower_case

    # Macros -- SCREAMING_SNAKE_CASE.
    - key: readability-identifier-naming.MacroDefinitionCase
      value: UPPER_CASE

    # Namespaces -- lower_case.
    - key: readability-identifier-naming.NamespaceCase
      value: lower_case

    # Loosen function size to accommodate dispatcher/router patterns.
    - key: readability-function-size.LineThreshold
      value: 120
    - key: readability-function-size.StatementThreshold
      value: 80
    - key: readability-function-size.BranchThreshold
      value: 16
    - key: readability-function-size.ParameterThreshold
      value: 6
    - key: readability-function-cognitive-complexity.Threshold
      value: 25

    # Modernize options.
    - key: modernize-use-default-member-init.UseAssignment
      value: true
    - key: modernize-loop-convert.MaxCopySize
      value: 16
    - key: modernize-pass-by-value.IncludeStyle
      value: google

    # Performance options.
    - key: performance-move-const-arg.CheckTriviallyCopyableMove
      value: false
    - key: performance-unnecessary-value-param.AllowedTypes
      value: 'std::shared_ptr;std::unique_ptr'

    # Bugprone tuning.
    - key: bugprone-argument-comment.StrictMode
      value: true
    - key: bugprone-assert-side-effect.AssertMacros
      value: 'assert,CMLB_ASSERT'
    - key: bugprone-suspicious-string-compare.WarnOnLogicalNotComparison
      value: true

    # Cppcoreguidelines tuning.
    - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
      value: true
    - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
      value: false
...
